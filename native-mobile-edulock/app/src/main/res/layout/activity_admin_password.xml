<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D32F2F"
    android:padding="24dp">

    <!-- Lock Icon -->
    <ImageView
        android:id="@+id/ivAdminLockIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_lock_big"
        android:tint="#FFFFFF" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvAdminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivAdminLockIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="ADMIN PROTECTION"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <!-- Warning -->
    <TextView
        android:id="@+id/tvAdminWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvAdminTitle"
        android:layout_marginTop="16dp"
        android:text="⚠️ Untuk menonaktifkan Device Admin, masukkan password admin sekolah."
        android:textSize="16sp"
        android:textColor="#FFCDD2"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <!-- Password Input Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvPasswordCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvAdminWarning"
        android:layout_marginTop="32dp"
        android:elevation="8dp"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password Admin"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <!-- Password Input -->
            <EditText
                android:id="@+id/etAdminPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_background"
                android:hint="Masukkan password admin"
                android:inputType="textPassword"
                android:maxLength="20"
                android:padding="16dp"
                android:textSize="18sp" />

            <!-- Info Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FFF3E0"
                android:padding="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_warning"
                    android:tint="#FF6F00" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Hanya admin sekolah yang memiliki password ini. Siswa TIDAK DIIZINKAN menonaktifkan aplikasi."
                    android:textSize="12sp"
                    android:textColor="#E65100" />

            </LinearLayout>

            <!-- Verify Button -->
            <Button
                android:id="@+id/btnVerifyPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Verifikasi Password"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50" />

            <!-- Cancel Button -->
            <Button
                android:id="@+id/btnCancelAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Batal"
                android:textColor="#666666"
                android:backgroundTint="#E0E0E0" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Warning Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:text="⚠️ Percobaan menonaktifkan tanpa password yang benar akan dicatat sebagai pelanggaran"
        android:textSize="12sp"
        android:textColor="#FFCDD2"
        android:gravity="center" />

</RelativeLayout>