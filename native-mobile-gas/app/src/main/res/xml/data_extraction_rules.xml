<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="app_session.xml" />
        <exclude domain="sharedpref" path="app_session" />
        <exclude domain="sharedpref" path="app_session_secure.xml" />
        <exclude domain="sharedpref" path="app_session_secure" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__.xml" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__.xml" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="app_session.xml" />
        <exclude domain="sharedpref" path="app_session" />
        <exclude domain="sharedpref" path="app_session_secure.xml" />
        <exclude domain="sharedpref" path="app_session_secure" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__.xml" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__.xml" />
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__" />
    </device-transfer>
</data-extraction-rules>
